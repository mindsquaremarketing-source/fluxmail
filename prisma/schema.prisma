generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id             String    @id @default(cuid())
  shopDomain     String    @unique
  accessToken    String
  firstName      String?
  lastName       String?
  email          String?
  phone          String?
  logoUrl        String?   @db.Text
  primaryColor   String?   @default("#1E40AF")
  secondaryColor String?   @default("#FFFFFF")
  bgColor        String?   @default("#FFFFFF")
  primaryText    String?   @default("#FFFFFF")
  secondaryText  String?   @default("#000000")
  bgText         String?   @default("#1F2937")
  fontFamily     String?   @default("Arial")
  buttonShape    String?   @default("rounded")
  companyName    String?
  website        String?
  country        String?
  state          String?
  city           String?
  zip            String?
  address        String?
  senderName     String?
  replyToEmail   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  contacts       Contact[]
}

model Contact {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  email     String
  firstName String?
  lastName  String?
  status    String   @default("subscribed")
  source    String   @default("shopify")
  addedAt   DateTime @default(now())

  @@unique([storeId, email])
}

model Campaign {
  id           String   @id @default(cuid())
  storeId      String
  name         String
  subject      String   @default("")
  htmlContent  String   @default("") @db.Text
  status       String   @default("draft")
  emailsSent   Int      @default(0)
  opens        Int      @default(0)
  clicks       Int      @default(0)
  placedOrders Int      @default(0)
  revenue      Float    @default(0)
  createdAt    DateTime @default(now())
}
